#!/usr/bin/env bash
##################################################################################
# Optimized IOMAD / Moodle backup script
#
# Backup layout:
#   archive_root/host/YYYYMMDD-HHMMSS-gitcommit/
#     ├── html.tar.gz
#     ├── moodledata.tar.gz       <-- compressed, excludes runtime directories
#     ├── database.sql
#     ├── PARAMS
#     └── backup-manifest.txt
#
# Major changes from the old version:
#   - Excludes Moodle runtime directories:
#       cache, localcache, sessions, temp, trashdir, lock
#   - Uses pigz if available, gzip otherwise.
#   - Uses safer mysqldump options for Moodle/IOMAD.
#   - Does not print the database password.
#   - Waits for remote rsync jobs instead of silently backgrounding them.
##################################################################################

set -Eeuo pipefail

declare -A CFG
declare -A IOMAD

##################################################################################
# Colours / formatting
##################################################################################

if command -v tput >/dev/null 2>&1 && [ -t 1 ]; then
    B="$(tput bold)"
    U="$(tput smul)"
    N="$(tput sgr0)"
    CYAN="$(tput setaf 6)"
    YELLOW="$(tput setaf 3)"
    RED="$(tput setaf 1)"
    GREEN="$(tput setaf 2)"
    RESET="$(tput sgr0)"
else
    B=""
    U=""
    N=""
    CYAN=""
    YELLOW=""
    RED=""
    GREEN=""
    RESET=""
fi

##################################################################################
# Helpers
##################################################################################

die() {
    echo "${RED}ERROR:${RESET} $*" >&2
    exit 1
}

warn() {
    echo "${YELLOW}WARNING:${RESET} $*" >&2
}

info() {
    echo "${CYAN}$*${RESET}"
}

cfg() {
    local key="$1"
    local default="${2:-}"
    printf '%s' "${CFG[$key]:-$default}"
}

line() {
    printf '%*s\n' "${COLUMNS:-80}" '' | tr ' ' '-'
}

ask_yes_no() {
    local prompt="$1"
    local default="$2"
    local answer

    while true; do
        read -r -p "${B}${prompt}:${N} [${default}] " answer
        answer="${answer:-$default}"

        case "$answer" in
            yes|no)
                printf '%s' "$answer"
                return 0
                ;;
            *)
                echo "Invalid - enter yes or no"
                ;;
        esac
    done
}

ask_digits() {
    local prompt="$1"
    local default="$2"
    local answer

    while true; do
        read -r -p "${B}${prompt}:${N} [${default}] " answer
        answer="${answer:-$default}"

        if [[ "$answer" =~ ^[0-9]+$ ]]; then
            printf '%s' "$answer"
            return 0
        fi

        echo "Invalid - digits only"
    done
}

countdown() {
    local minutes="$1"

    if [ "$minutes" -le 0 ]; then
        return 0
    fi

    local start
    start="$(( $(date '+%s') + minutes * 60 ))"

    while [ "$start" -ge "$(date +%s)" ]; do
        local remaining
        remaining="$(( start - $(date +%s) ))"
        printf '%s\r' "$(date -u -d "@$remaining" +%H:%M:%S)"
        sleep 0.5
    done

    echo
}

require_command() {
    local cmd="$1"
    command -v "$cmd" >/dev/null 2>&1 || die "Required command not found: $cmd"
}

read_settings() {
    local file="$1"

    [ -f "$file" ] || die "No settings.cfg found. Rename/modify settings.cfg.default to settings.cfg"

    while IFS= read -r line_raw || [ -n "$line_raw" ]; do
        # Remove Windows CR if present
        line_raw="${line_raw%$'\r'}"

        # Skip blanks and comments
        [[ -z "$line_raw" ]] && continue
        [[ "$line_raw" =~ ^[[:space:]]*# ]] && continue

        if [[ "$line_raw" == *"="* ]]; then
            local key="${line_raw%%=*}"
            local value="${line_raw#*=}"

            # Trim simple whitespace around key
            key="$(echo "$key" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"

            CFG["$key"]="$value"
        fi
    done < "$file"
}

parse_iomad_config() {
    local config_php="$1"

    [ -f "$config_php" ] || die "IOMAD/Moodle config.php not found: $config_php"

    local parsed
    parsed="$(
        php -r '
            $file = $argv[1];
            $txt = file_get_contents($file);

            $keys = ["dbname", "dbuser", "dbpass", "dbhost", "dbport", "dataroot"];

            foreach ($keys as $key) {
                $pattern = "/\\\$CFG->" . preg_quote($key, "/") . "\\s*=\\s*([\"\\x27])(.+?)\\1\\s*;/s";
                if (preg_match($pattern, $txt, $m)) {
                    echo $key . "=" . $m[2] . PHP_EOL;
                }
            }
        ' "$config_php"
    )"

    while IFS='=' read -r key value; do
        [ -z "${key:-}" ] && continue
        IOMAD["$key"]="$value"
    done <<< "$parsed"

    [ -n "${IOMAD[dbname]:-}" ] || die "Could not read dbname from $config_php"
    [ -n "${IOMAD[dbuser]:-}" ] || die "Could not read dbuser from $config_php"
    [ -n "${IOMAD[dbpass]:-}" ] || die "Could not read dbpass from $config_php"
}

make_mysql_defaults_file() {
    local mysql_cnf
    mysql_cnf="$(mktemp)"

    chmod 600 "$mysql_cnf"

    {
        echo "[client]"
        echo "user=${IOMAD[dbuser]}"
        echo "password=${IOMAD[dbpass]}"

        if [ -n "${IOMAD[dbhost]:-}" ]; then
            echo "host=${IOMAD[dbhost]}"
        fi

        if [ -n "${IOMAD[dbport]:-}" ]; then
            echo "port=${IOMAD[dbport]}"
        fi
    } > "$mysql_cnf"

    printf '%s' "$mysql_cnf"
}

##################################################################################
# Initial setup
##################################################################################

clear

SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SETTINGS_FILE="$SCRIPT_PATH/settings.cfg"

read_settings "$SETTINGS_FILE"

# Defaults for optional settings
CFG[enabled]="$(cfg enabled no)"
CFG[auto_update]="$(cfg auto_update no)"
CFG[rsync_enabled]="$(cfg rsync_enabled no)"
CFG[rsyncsandbox_enabled]="$(cfg rsyncsandbox_enabled no)"
CFG[delay_timer]="$(cfg delay_timer 0)"
CFG[enable_host]="$(cfg enable_host yes)"
CFG[host_htmlroot]="$(cfg host_htmlroot html)"
CFG[host_dataroot]="$(cfg host_dataroot moodledata)"
CFG[host_config]="$(cfg host_config config.php)"
CFG[compression_level]="$(cfg compression_level 3)"
CFG[stop_moodle_cron]="$(cfg stop_moodle_cron no)"
CFG[rsync_delete_remote]="$(cfg rsync_delete_remote no)"

[ "$(cfg enabled)" = "yes" ] || die "Script not enabled. Check settings.cfg: enabled=yes"

require_command awk
require_command sed
require_command grep
require_command find
require_command sort
require_command tail
require_command du
require_command tar
require_command rsync
require_command mysqldump
require_command php
require_command sudo
require_command git

if command -v pigz >/dev/null 2>&1; then
    COMPRESS_CMD=(pigz "-$(cfg compression_level 3)")
    COMPRESS_NAME="pigz -$(cfg compression_level 3)"
else
    COMPRESS_CMD=(gzip)
    COMPRESS_NAME="gzip"
    warn "pigz not found. Falling back to gzip. Install with: sudo apt install pigz"
fi

if command -v pv >/dev/null 2>&1; then
    HAVE_PV="yes"
else
    HAVE_PV="no"
    warn "pv not found. Progress bars will be skipped. Install with: sudo apt install pv"
fi

# Determine real user
if [ "$EUID" -eq 0 ] && [ -n "${SUDO_USER:-}" ]; then
    CURRENT_USER="$SUDO_USER"
else
    CURRENT_USER="$(logname 2>/dev/null || whoami)"
fi

CURRENT_HOME="$(getent passwd "$CURRENT_USER" | cut -d: -f6)"
export HOME="$CURRENT_HOME"

# Apache user
www_user="$(
    bash -c 'source /etc/apache2/envvars >/dev/null 2>&1; echo "${APACHE_RUN_USER:-www-data}"'
)"

SSH_ID="$(cfg ssh_identity "$HOME/.ssh/id_firetrain")"
SSH_CMD="ssh -o BatchMode=yes -o IdentitiesOnly=yes -i ${SSH_ID}"

##################################################################################
# Sudo check
##################################################################################

if [ "$EUID" -eq 0 ]; then
    echo "Running as root/sudo"
else
    sudo -k

    if sudo true; then
        echo "Password correct - sudo rights allowed"
    else
        die "Wrong password or no sudo access"
    fi
fi

##################################################################################
# Pick host
##################################################################################

WWW_ROOTDIR="$(cfg www_rootdir)"

[ -n "$WWW_ROOTDIR" ] || die "settings.cfg missing: www_rootdir="
[ -d "$WWW_ROOTDIR" ] || die "www_rootdir does not exist: $WWW_ROOTDIR"

cd "$WWW_ROOTDIR"

line
echo "${B}${CYAN}Choose the IOMAD host to back up and/or upgrade:${RESET} enter number"
line
echo

PS3="${YELLOW}Enter selection: ${RESET}"

select host_dir in $(find . -maxdepth 1 -type d ! -name '.*' -printf '%P\n' | sort); do
    if [[ -n "${host_dir:-}" ]]; then
        break
    else
        echo "${RED}>>> Invalid Selection${RESET}"
    fi
done

VHOST_ROOTPATH="${WWW_ROOTDIR%/}/$host_dir"
VHOST_HTMLPATH="$VHOST_ROOTPATH/$(cfg host_htmlroot)"
VHOST_DATAPATH="$VHOST_ROOTPATH/$(cfg host_dataroot)"
IOMAD_PHP="$VHOST_HTMLPATH/$(cfg host_config)"

[ -d "$VHOST_HTMLPATH" ] || die "HTML path not found: $VHOST_HTMLPATH"
[ -f "$IOMAD_PHP" ] || die "IOMAD config file not found: $IOMAD_PHP"

parse_iomad_config "$IOMAD_PHP"

# Prefer dataroot from config.php if it exists
if [ -n "${IOMAD[dataroot]:-}" ] && [ -d "${IOMAD[dataroot]}" ]; then
    VHOST_DATAPATH="${IOMAD[dataroot]}"
fi

[ -d "$VHOST_DATAPATH" ] || die "Moodledata path not found: $VHOST_DATAPATH"

BACKUPDATE="$(date +%Y%m%d-%H%M%S)"

if git -C "$VHOST_HTMLPATH" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    CURRENT_COMMIT="$(git -C "$VHOST_HTMLPATH" log -1 --format=%h 2>/dev/null || echo nogit)"
else
    CURRENT_COMMIT="nogit"
fi

ARCHIVE_BASE="$(cfg archive_root)"
[ -n "$ARCHIVE_BASE" ] || die "settings.cfg missing: archive_root="

ARCHIVE_BASE="${ARCHIVE_BASE%/}/$host_dir"
ARCHIVE_PATH="$ARCHIVE_BASE/$BACKUPDATE-$CURRENT_COMMIT"

##################################################################################
# Interactive options
##################################################################################

echo
CFG[auto_update]="$(ask_yes_no "Upgrade after backup? (yes/no)" "$(cfg auto_update)")"
echo

CFG[rsync_enabled]="$(ask_yes_no "RSYNC to offsite location? (yes/no)" "$(cfg rsync_enabled)")"
echo

CFG[rsyncsandbox_enabled]="$(ask_yes_no "RSYNC to sandbox location? (yes/no)" "$(cfg rsyncsandbox_enabled)")"
echo

line
echo "Delay in minutes before script execution"
echo "Press ENTER for default $(cfg delay_timer) minutes"
echo "Enter 0 for immediate execution"
line
CFG[delay_timer]="$(ask_digits "Default delay timer is set, enter new delay or ENTER" "$(cfg delay_timer)")"
echo

CFG[enable_host]="$(ask_yes_no "Re-enable site after operation? (yes/no)" "$(cfg enable_host)")"
echo

##################################################################################
# Summary
##################################################################################

clear
line
echo "- ${B}General Options${N}"
line
echo "-- Update with git?          :   $(cfg auto_update)"
echo "-- Delay timer               :   $(cfg delay_timer) minutes"
echo "-- Re-enable host?           :   $(cfg enable_host)"
echo "-- Webserver user            :   $www_user"
echo "-- Current user              :   $CURRENT_USER"
echo "-- Host directory            :   $host_dir"
echo "-- Script path               :   $SCRIPT_PATH"
echo "-- Compression               :   $COMPRESS_NAME"
echo "-- Stop Moodle cron?         :   $(cfg stop_moodle_cron)"
line
echo "- ${B}Host Options${N}"
line
echo "-- Webserver root path       :   $WWW_ROOTDIR"
echo "-- Site path                 :   $VHOST_ROOTPATH"
echo "-- Site HTML path            :   $VHOST_HTMLPATH"
echo "-- Site data path            :   $VHOST_DATAPATH"
echo "-- Database name             :   ${IOMAD[dbname]}"
echo "-- Database username         :   ${IOMAD[dbuser]}"
echo "-- Database host             :   ${IOMAD[dbhost]:-localhost/default}"
echo "-- Archive base              :   $ARCHIVE_BASE"
echo "-- Archive path              :   $ARCHIVE_PATH"
line
echo "- ${B}RSYNC Offsite Options${N}"
line
echo "-- RSYNC offsite?            :   $(cfg rsync_enabled)"
echo "-- RSYNC remote user         :   $(cfg rsync_remoteuser)"
echo "-- RSYNC remote host         :   $(cfg rsync_remotehost)"
echo "-- RSYNC remote path         :   $(cfg rsync_remotepath)"
echo "-- RSYNC full path           :   $(cfg rsync_remotepath)/$host_dir"
line
echo "- ${B}RSYNC Sandbox Options${N}"
line
echo "-- RSYNC to sandbox?         :   $(cfg rsyncsandbox_enabled)"
echo "-- RSYNC sandbox user        :   $(cfg rsync_sandboxuser)"
echo "-- RSYNC sandbox host        :   $(cfg rsync_sandboxhost)"
echo "-- RSYNC sandbox path        :   $(cfg rsync_sandboxpath)"
echo "-- RSYNC sandbox full path   :   $(cfg rsync_sandboxpath)/$host_dir"
line
echo
echo "- ${B}CTRL+C to abort, press ENTER to continue${N}"
line
read -r

##################################################################################
# Cleanup handling
##################################################################################

MAINTENANCE_SET=0
CRON_STOPPED=0
MYSQL_CNF=""

cleanup() {
    local status=$?

    if [ -n "${MYSQL_CNF:-}" ] && [ -f "$MYSQL_CNF" ]; then
        rm -f "$MYSQL_CNF"
    fi

    if [ "$CRON_STOPPED" -eq 1 ]; then
        echo "- Restarting configured Moodle cron services/timers"

        if [ -n "$(cfg moodle_cron_service)" ]; then
            sudo systemctl start "$(cfg moodle_cron_service)" 2>/dev/null || true
        fi

        if [ -n "$(cfg moodle_cron_timer)" ]; then
            sudo systemctl start "$(cfg moodle_cron_timer)" 2>/dev/null || true
        fi
    fi

    if [ "$MAINTENANCE_SET" -eq 1 ] && [ "$(cfg enable_host)" = "yes" ]; then
        echo "- Disabling maintenance mode and restoring access"
        sudo -u "$www_user" php "$VHOST_HTMLPATH/admin/cli/maintenance.php" --disable || true
    elif [ "$MAINTENANCE_SET" -eq 1 ]; then
        echo "${B}- Maintenance mode was left enabled by request -${N}"
    fi

    if [ "$status" -ne 0 ]; then
        echo
        echo "${RED}Backup script exited with errors.${RESET}"
    fi

    exit "$status"
}

trap cleanup EXIT

##################################################################################
# Backup functions
##################################################################################

enable_maintenance() {
    local delay
    delay="$(cfg delay_timer)"

    cd "$SCRIPT_PATH"

    if [ "$delay" -eq 0 ]; then
        echo "- Setting site to maintenance mode immediately"
        sudo -u "$www_user" php "$VHOST_HTMLPATH/admin/cli/maintenance.php" --enable
    else
        echo "- Setting maintenance mode warning for all users: enable in $delay minute(s)"
        sudo -u "$www_user" php "$VHOST_HTMLPATH/admin/cli/maintenance.php" "--enablelater=$delay"
        countdown "$delay"

        echo "- Enabling maintenance mode now"
        sudo -u "$www_user" php "$VHOST_HTMLPATH/admin/cli/maintenance.php" --enable
    fi

    MAINTENANCE_SET=1

    if [ -f "$VHOST_DATAPATH/climaintenance.html.off" ]; then
        echo "- Setting custom offline page"
        cp "$VHOST_DATAPATH/climaintenance.html.off" "$VHOST_DATAPATH/climaintenance.html"
    fi
}

disable_maintenance_if_set() {
    if [ "$MAINTENANCE_SET" -eq 1 ] && [ "$(cfg enable_host)" = "yes" ]; then
        echo
        echo "- Disabling maintenance mode and restoring access"
        sudo -u "$www_user" php "$VHOST_HTMLPATH/admin/cli/maintenance.php" --disable || true
        MAINTENANCE_SET=0
    fi
}

stop_moodle_cron_if_configured() {
    if [ "$(cfg stop_moodle_cron)" != "yes" ]; then
        echo "- Moodle cron stop disabled. Set stop_moodle_cron=yes and moodle_cron_service/moodle_cron_timer if wanted."
        return 0
    fi

    local stopped_any=0

    if [ -n "$(cfg moodle_cron_timer)" ]; then
        echo "- Stopping Moodle cron timer: $(cfg moodle_cron_timer)"
        sudo systemctl stop "$(cfg moodle_cron_timer)"
        stopped_any=1
    fi

    if [ -n "$(cfg moodle_cron_service)" ]; then
        echo "- Stopping Moodle cron service: $(cfg moodle_cron_service)"
        sudo systemctl stop "$(cfg moodle_cron_service)" 2>/dev/null || true
        stopped_any=1
    fi

    if [ "$stopped_any" -eq 1 ]; then
        CRON_STOPPED=1
    else
        warn "stop_moodle_cron=yes, but no moodle_cron_service or moodle_cron_timer configured."
    fi
}

make_archive_dirs() {
    echo "- Creating archive path: $ARCHIVE_PATH"
    sudo mkdir -p "$ARCHIVE_PATH"
    sudo chown -R "$CURRENT_USER:$CURRENT_USER" "$ARCHIVE_BASE"
}

write_params_and_manifest() {
    cat > "$ARCHIVE_PATH/PARAMS" <<EOF
www_rootdir=$WWW_ROOTDIR
www_hostdir=$VHOST_ROOTPATH
html_path=$VHOST_HTMLPATH
moodledata_path=$VHOST_DATAPATH
archive_root=$(cfg archive_root)
archive_base=$ARCHIVE_BASE
archive_path=$ARCHIVE_PATH
last_backup=$(basename "$ARCHIVE_PATH")
database_dump=${IOMAD[dbname]}.sql
html_archive=$(cfg host_htmlroot).tar.gz
moodledata_backup=$(cfg host_dataroot).tar.gz
backup_type=tar-gz-compressed
git_commit=$CURRENT_COMMIT
created_at=$BACKUPDATE
EOF

    cat > "$ARCHIVE_PATH/backup-manifest.txt" <<EOF
IOMAD/Moodle backup manifest
============================

Host:
  $host_dir

Created:
  $BACKUPDATE

Git commit:
  $CURRENT_COMMIT

HTML path:
  $VHOST_HTMLPATH

Moodledata path:
  $VHOST_DATAPATH

Database:
  ${IOMAD[dbname]}

Backup contents:
  $(cfg host_htmlroot).tar.gz
  ${IOMAD[dbname]}.sql
  $(cfg host_dataroot).tar.gz

Moodledata excluded directories:
  cache/
  localcache/
  sessions/
  temp/
  trashdir/
  lock/

Notes:
  moodledata is compressed as a tar.gz archive.
  Runtime directories (cache, sessions, temp, etc.) are excluded.
EOF
}

backup_html() {
    local html_name
    html_name="$(basename "$VHOST_HTMLPATH")"

    echo
    echo "- Creating ${B}${html_name}.tar.gz${N}"

    local html_size
    html_size="$(du -sb "$VHOST_HTMLPATH" | awk '{print $1}')"

    if [ "$HAVE_PV" = "yes" ]; then
        sudo tar -C "$VHOST_ROOTPATH" -cf - "$html_name" \
            | pv -s "$html_size" \
            | "${COMPRESS_CMD[@]}" > "$ARCHIVE_PATH/${html_name}.tar.gz"
    else
        sudo tar -C "$VHOST_ROOTPATH" -cf - "$html_name" \
            | "${COMPRESS_CMD[@]}" > "$ARCHIVE_PATH/${html_name}.tar.gz"
    fi
}

backup_database() {
    echo
    echo "- Dumping database into: ${B}${IOMAD[dbname]}.sql${N}"

    MYSQL_CNF="$(make_mysql_defaults_file)"

    mysqldump \
        --defaults-extra-file="$MYSQL_CNF" \
        --single-transaction \
        --quick \
        --routines \
        --triggers \
        --events \
        --create-options \
        --default-character-set=utf8mb4 \
        "${IOMAD[dbname]}" \
        > "$ARCHIVE_PATH/${IOMAD[dbname]}.sql"

    rm -f "$MYSQL_CNF"
    MYSQL_CNF=""
}

backup_moodledata_tar() {
    local data_name
    data_name="$(basename "$VHOST_DATAPATH")"

    echo
    echo "- Creating ${B}${data_name}.tar.gz${N}"

    local data_size
    data_size="$(du -sb "$VHOST_DATAPATH" | awk '{print $1}')"

    if [ "$HAVE_PV" = "yes" ]; then
        sudo tar -C "$VHOST_ROOTPATH" -cf - \
            --exclude="$data_name/cache" \
            --exclude="$data_name/localcache" \
            --exclude="$data_name/sessions" \
            --exclude="$data_name/temp" \
            --exclude="$data_name/trashdir" \
            --exclude="$data_name/lock" \
            "$data_name" \
            | pv -s "$data_size" \
            | "${COMPRESS_CMD[@]}" > "$ARCHIVE_PATH/${data_name}.tar.gz"
    else
        sudo tar -C "$VHOST_ROOTPATH" -cf - \
            --exclude="$data_name/cache" \
            --exclude="$data_name/localcache" \
            --exclude="$data_name/sessions" \
            --exclude="$data_name/temp" \
            --exclude="$data_name/trashdir" \
            --exclude="$data_name/lock" \
            "$data_name" \
            | "${COMPRESS_CMD[@]}" > "$ARCHIVE_PATH/${data_name}.tar.gz"
    fi
}

git_update_if_requested() {
    if [ "$(cfg auto_update)" = "yes" ]; then
        echo
        echo "- Beginning git pull"
        sudo -u "$www_user" git -C "$VHOST_HTMLPATH" pull
    fi
}

sync_remote_tree() {
    local label="$1"
    local remote_user="$2"
    local remote_host="$3"
    local remote_path="$4"

    [ -n "$remote_user" ] || die "$label rsync user is empty"
    [ -n "$remote_host" ] || die "$label rsync host is empty"
    [ -n "$remote_path" ] || die "$label rsync path is empty"

    local delete_args=()
    if [ "$(cfg rsync_delete_remote)" = "yes" ]; then
        delete_args=(--delete)
    fi

    echo
    echo "- Starting $label rsync"
    echo "  Source: $ARCHIVE_PATH/"
    echo "  Dest  : ${remote_user}@${remote_host}:${remote_path%/}/"

    rsync -aHz --numeric-ids --info=progress2 \
        "${delete_args[@]}" \
        -e "$SSH_CMD" \
        "$ARCHIVE_PATH/" \
        "${remote_user}@${remote_host}:${remote_path%/}/"
}

remote_rsyncs_if_requested() {
    local pids=()

    if [ "$(cfg rsync_enabled)" = "yes" ]; then
        sync_remote_tree \
            "offsite" \
            "$(cfg rsync_remoteuser)" \
            "$(cfg rsync_remotehost)" \
            "$(cfg rsync_remotepath)" &
        pids+=("$!")
    fi

    if [ "$(cfg rsyncsandbox_enabled)" = "yes" ]; then
        sync_remote_tree \
            "sandbox" \
            "$(cfg rsync_sandboxuser)" \
            "$(cfg rsync_sandboxhost)" \
            "$(cfg rsync_sandboxpath)" &
        pids+=("$!")
    fi

    if [ "${#pids[@]}" -gt 0 ]; then
        echo
        echo "- Waiting for rsync job(s) to complete"

        local pid
        for pid in "${pids[@]}"; do
            wait "$pid"
        done
    fi
}

fix_archive_ownership() {
    echo
    echo "- Changing ownership of backup files"
    sudo chown -R "$CURRENT_USER:$CURRENT_USER" "$ARCHIVE_PATH"
}

##################################################################################
# Main
##################################################################################

start_backup() {
    clear
    line
    echo "- BEGINNING BACKUP OF PRODUCTION WEBSITE"
    line

    enable_maintenance
    stop_moodle_cron_if_configured
    make_archive_dirs
    write_params_and_manifest

    backup_html
    backup_moodledata_tar
    backup_database

    git_update_if_requested

    fix_archive_ownership

    disable_maintenance_if_set

    remote_rsyncs_if_requested

    line
    echo "${GREEN}- Backup completed successfully${RESET}"
    echo "- Archive path:"
    echo "  $ARCHIVE_PATH"
    line
}

start_backup

exit 0
